# ── Network ───────────────────────────────────────────────────────────────────
# Localnet (default):
ANCHOR_PROVIDER_URL=http://127.0.0.1:8899
ARCIUM_CLUSTER_OFFSET=0

# Devnet:
# ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
# ARCIUM_CLUSTER_OFFSET=456

# Mainnet-alpha:
# ANCHOR_PROVIDER_URL=https://api.mainnet-beta.solana.com
# ARCIUM_CLUSTER_OFFSET=2026

# ── Keypairs ──────────────────────────────────────────────────────────────────
ANCHOR_WALLET=~/.config/solana/id.json
# Use a DIFFERENT keypair than ANCHOR_WALLET for unlinkability.
RELAYER_KEYPAIR_PATH=~/.config/solana/relayer.json
# Sender wallet for API-driven transfers. If omitted, falls back to ANCHOR_WALLET.
SENDER_WALLET=~/.config/solana/sender.json

# ── Program (update after arcium deploy) ─────────────────────────────────────
LOWKIE_PROGRAM_ID=LowkiePoo1111111111111111111111111111111111
LOWKIE_CIRCUIT_SOURCE_MODE=auto
# `auto` selects offchain when any LOWKIE_OFFCHAIN_* URL is configured,
# otherwise it falls back to onchain uploads.
# Required when LOWKIE_CIRCUIT_SOURCE_MODE resolves to offchain.
# Example: https://cdn.example.com/lowkie-circuits/
# LOWKIE_OFFCHAIN_CIRCUIT_BASE_URL=
# Optional per-circuit overrides when files are hosted at different URLs.
# LOWKIE_OFFCHAIN_INIT_POOL_BALANCE_URL=
# LOWKIE_OFFCHAIN_DEPOSIT_TO_POOL_URL=
# LOWKIE_OFFCHAIN_WITHDRAW_FROM_POOL_URL=
# LOWKIE_OFFCHAIN_COMPACT_REGISTRY_URL=

# ── Relayer ───────────────────────────────────────────────────────────────────
RELAYER_DELAY_MS=15000
# NEVER enable in production — logs amounts, addresses, and secrets.
LOWKIE_LOG_SENSITIVE_DATA=false

# ── Backend API (recommended over FRONTEND_HOST/PORT) ────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=5174
LOWKIE_REQUIRE_API_AUTH=false
# LOWKIE_API_AUTH_TOKEN=replace-with-a-long-random-secret
# LOWKIE_ALLOWED_ORIGINS=https://app.example.com
LOWKIE_API_RATE_LIMIT_WINDOW_MS=60000
LOWKIE_API_RATE_LIMIT_MAX_REQUESTS=10
LOWKIE_SERIALIZE_SEND_REQUESTS=true
LOWKIE_MAX_REQUEST_BODY_BYTES=262144
LOWKIE_MAX_AMOUNT_SOL=100
LOWKIE_MIN_DELAY_MS=1000
LOWKIE_MAX_DELAY_MS=120000

# Unsafe local demo features are explicit opt-ins only.
LOWKIE_ALLOW_UNSAFE_LOCALNET=false
LOWKIE_AUTO_COMPACT_REGISTRY=false
LOWKIE_SKIP_PREFLIGHT=false

# Plaintext note-file flow is disabled by default.
# Only enable in controlled local workflows.
LOWKIE_WRITE_NOTE_FILE=false
LOWKIE_ALLOW_PLAINTEXT_NOTE_FILE=false
LOWKIE_NOTE_FILE=./recovery/lowkie-note.json
