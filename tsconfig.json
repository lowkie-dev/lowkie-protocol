{
  "compilerOptions": {
    "types":          ["mocha", "node"],
    "typeRoots":      ["./node_modules/@types"],
    "lib":            ["es2022"],
    "module":         "NodeNext",
    "target":         "es2022",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "NodeNext",
    "strict":         true,
    "skipLibCheck":   true
  }
}
