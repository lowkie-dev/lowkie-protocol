{
  "compilerOptions": {
    "types": ["mocha", "node"],
    "typeRoots": ["./node_modules/@types"],
    "lib": ["es2022"],
    "module": "NodeNext",
    "target": "es2022",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["client/**/*.ts", "apps/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts", "packages/**/*.ts"],
  "exclude": ["node_modules", "target", "build"]
}
